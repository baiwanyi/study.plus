{
    "compilerOptions": {
        "target": "ES2023",
        "lib": ["ES2023"],
        "erasableSyntaxOnly": true,
        "module": "ESNext",
        "moduleDetection": "force",
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "isolatedModules": true,
        "verbatimModuleSyntax": true,
        "types": ["node"],
        "noEmit": true,
        "skipLibCheck": true,
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "paths": {
            "@shared/*": ["../shared/src/*"]
        }
    },
    "include": ["src"]
}
