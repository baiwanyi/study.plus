/**
 * 【PC 小程序】PC 端全局样式覆盖
 * 通过 .pc-mode 前缀与移动端样式互不干扰
 */

/* PC 全局字体基准 */
.pc-mode page,
.pc-mode .page {
    font-size: 14px;
}

/* 最大宽度容器 + 居中 */
.pc-mode .page--wide {
    max-width: 100%;
    padding: 0;
    margin: 0;
    min-height: calc(100vh - 44px);
}

/* 侧边栏 + 内容区布局 */
.pc-mode .pc-body {
    display: flex;
    min-height: calc(100vh - 44px);
}

.pc-mode .pc-sidebar {
    width: 240px;
    flex-shrink: 0;
    background: #FFFFFF;
    border-right: 1px solid #E5E7EB;
    display: flex;
    flex-direction: column;
}

.pc-mode .pc-content {
    flex: 1;
    padding: 24px 32px;
    overflow-y: auto;
    max-width: 960px;
}

/* hover 效果（PC 鼠标悬停反馈） */
.pc-mode .card:hover,
.pc-mode .entry-card:hover {
    box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
    cursor: pointer;
}

.pc-mode .t-cell:hover {
    background: #F9FAFB;
}

/* PC 弹窗（居中模态替代 bottom popup） */
.pc-mode .pc-modal-mask {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.4);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
}

.pc-mode .pc-modal-body {
    background: #FFFFFF;
    border-radius: 12px;
    padding: 32px;
    min-width: 400px;
    max-width: 560px;
    max-height: 80vh;
    overflow-y: auto;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
}

/* 隐藏移动端特有的浮动按钮 */
.pc-mode .t-fab {
    display: none !important;
}

/* 2 列网格 */
.pc-mode .pc-grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
}

/* 3 列网格 */
.pc-mode .pc-grid-3 {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 16px;
}

/* 表单元素最大宽度限制 */
.pc-mode .t-input {
    max-width: 400px;
}

.pc-mode .t-textarea {
    max-width: 500px;
}

/* 隐藏 rpx 字号溢出 */
.pc-mode .page,
.pc-mode .card-title,
.pc-mode .hero-title {
    font-size: revert;
}
