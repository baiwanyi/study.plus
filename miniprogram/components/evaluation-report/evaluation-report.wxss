.eval-report {
    padding: 8rpx 0;
}
.eval-report__score {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 180rpx;
    height: 180rpx;
    margin: 0 auto 28rpx;
    border-radius: 50%;
    background: linear-gradient(135deg, #07C160, #3A7AFE);
    color: #fff;
}
.eval-report__score-num {
    font-size: 64rpx;
    font-weight: 700;
    line-height: 1;
}
.eval-report__score-label {
    margin-top: 8rpx;
    font-size: 22rpx;
    opacity: 0.9;
}
.eval-report__section {
    margin-bottom: 24rpx;
}
.eval-report__section-title {
    font-size: 28rpx;
    font-weight: 600;
    color: #1A1A1A;
    margin-bottom: 10rpx;
}
.eval-report__section-body {
    font-size: 26rpx;
    line-height: 1.7;
    color: #6B7280;
    white-space: pre-wrap;
}
.eval-report__empty {
    color: #6B7280;
    font-size: 26rpx;
    text-align: center;
    padding: 32rpx 0;
}
