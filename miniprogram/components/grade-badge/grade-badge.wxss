.grade-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 16rpx;
    font-weight: 600;
    line-height: 1;
}
.grade-badge--normal {
    padding: 8rpx 18rpx;
    font-size: 26rpx;
}
.grade-badge--large {
    padding: 12rpx 28rpx;
    font-size: 34rpx;
}
