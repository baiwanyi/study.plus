.selector {
    display: flex;
    gap: 16rpx;
    overflow-x: auto;
    padding: 4rpx 0;
}

.chip {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 132rpx;
    padding: 14rpx 20rpx;
    border-radius: 20rpx;
    background: #F2F4F7;
    border: 2rpx solid transparent;
}

.chip--active {
    background: #E7F8EE;
    border-color: #07C160;
}

.chip-name {
    font-size: 28rpx;
    font-weight: 600;
    color: #1A1A1A;
}

.chip-grade {
    font-size: 22rpx;
    color: #6B7280;
    margin-top: 4rpx;
}
