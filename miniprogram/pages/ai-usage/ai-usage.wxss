.page {
    min-height: 100vh;
    padding: 24rpx;
    background: #F7F8FA;
}
.page__loading {
    padding-top: 120rpx;
    text-align: center;
}
.summary-card {
    background: linear-gradient(135deg, #07C160, #3A7AFE);
    border-radius: 24rpx;
    padding: 32rpx;
    color: #fff;
    margin-bottom: 24rpx;
}
.summary-card__title {
    font-size: 26rpx;
    opacity: 0.9;
}
.summary-card__total {
    font-size: 64rpx;
    font-weight: 700;
    margin: 8rpx 0 20rpx;
}
.summary-card__unit {
    font-size: 26rpx;
    font-weight: 400;
    opacity: 0.85;
}
.summary-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 24rpx;
    padding: 8rpx 0;
    opacity: 0.95;
}
