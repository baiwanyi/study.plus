.page {
    min-height: 100vh;
    background: #f7f8fa;
    padding-bottom: 160rpx;
}

.center-wrap {
    display: flex;
    justify-content: center;
    padding: 120rpx 0;
}

.records {
    margin-top: 16rpx;
}

.note {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 8rpx;
}

.cost {
    font-size: 32rpx;
    font-weight: 600;
    color: #FA5151;
}

.footer {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 16rpx 32rpx calc(16rpx + env(safe-area-inset-bottom));
    background: #f7f8fa;
}

.form {
    padding: 40rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
}

.form-title {
    font-size: 34rpx;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 24rpx;
}

.form-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24rpx 0;
}

.form-label {
    font-size: 28rpx;
    color: #1a1a1a;
}
