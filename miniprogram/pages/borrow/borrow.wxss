.page {
    min-height: 100vh;
    background: #f7f8fa;
    padding-bottom: 160rpx;
}

.summary-card {
    margin: 24rpx 32rpx;
    background: linear-gradient(135deg, #ff8c00 0%, #ffb347 100%);
    border-radius: 24rpx;
    padding: 36rpx 32rpx;
    color: #fff;
    box-shadow: 0 12rpx 32rpx rgba(255, 140, 0, 0.25);
}

.summary-row {
    display: flex;
    justify-content: space-around;
}

.summary-item {
    display: flex;
    flex-direction: column;
    align-items: center;
}

.item-num {
    font-size: 40rpx;
    font-weight: 600;
}

.item-label {
    font-size: 22rpx;
    opacity: 0.9;
    margin-top: 4rpx;
}

.tip {
    font-size: 22rpx;
    opacity: 0.9;
    margin-top: 20rpx;
    line-height: 1.6;
}

.center-wrap {
    display: flex;
    justify-content: center;
    padding: 120rpx 0;
}

.records {
    margin-top: 16rpx;
}

.footer {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 16rpx 32rpx calc(16rpx + env(safe-area-inset-bottom));
    background: #f7f8fa;
}

.form {
    padding: 40rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
}

.form-title {
    font-size: 34rpx;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 24rpx;
}

.form-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24rpx 0;
}

.form-label {
    font-size: 28rpx;
    color: #1a1a1a;
}
