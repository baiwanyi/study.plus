.page {
    min-height: 100vh;
    background: #f7f8fa;
    padding-bottom: 40rpx;
}

.summary-card {
    margin: 24rpx 32rpx;
    background: linear-gradient(135deg, #07c160 0%, #3ac97a 100%);
    border-radius: 24rpx;
    padding: 36rpx 32rpx;
    color: #fff;
    box-shadow: 0 12rpx 32rpx rgba(7, 193, 96, 0.25);
}

.summary-balance {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-bottom: 24rpx;
}

.balance-num {
    font-size: 72rpx;
    font-weight: 600;
    line-height: 1.1;
}

.balance-label {
    font-size: 24rpx;
    opacity: 0.85;
    margin-top: 4rpx;
}

.summary-row {
    display: flex;
    justify-content: space-around;
    border-top: 1rpx solid rgba(255, 255, 255, 0.25);
    padding-top: 24rpx;
}

.summary-item {
    display: flex;
    flex-direction: column;
    align-items: center;
}

.item-num {
    font-size: 32rpx;
    font-weight: 600;
}

.item-label {
    font-size: 22rpx;
    opacity: 0.85;
    margin-top: 4rpx;
}

.summary-actions {
    display: flex;
    gap: 16rpx;
    margin-top: 24rpx;
    justify-content: center;
}

.quick-entry {
    display: flex;
    gap: 24rpx;
    margin: 0 32rpx;
}

.entry {
    flex: 1;
    background: #fff;
    border-radius: 20rpx;
    padding: 28rpx;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12rpx;
    font-size: 26rpx;
    color: #1a1a1a;
    box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.center-wrap {
    display: flex;
    justify-content: center;
    padding: 120rpx 0;
}

.records {
    margin-top: 16rpx;
}

.amount {
    font-size: 32rpx;
    font-weight: 600;
}

.form {
    padding: 40rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
}

.form-title {
    font-size: 34rpx;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 24rpx;
}
