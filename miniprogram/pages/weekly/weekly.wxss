.page {
    min-height: 100vh;
    padding: 24rpx;
    background: #F7F8FA;
}
.page__loading {
    padding-top: 120rpx;
    text-align: center;
}
.report-list {
    display: flex;
    flex-direction: column;
}
.report-card {
    background: #fff;
    border-radius: 24rpx;
    padding: 28rpx;
    margin-bottom: 20rpx;
    box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}
.report-card__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14rpx;
}
.report-card__title {
    font-size: 30rpx;
    font-weight: 600;
    color: #1A1A1A;
}
.report-card__preview {
    font-size: 26rpx;
    color: #6B7280;
    line-height: 1.6;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
}
.form-sheet,
.detail-sheet {
    max-height: 86vh;
    overflow-y: auto;
    padding: 32rpx;
    background: #fff;
    border-radius: 32rpx 32rpx 0 0;
}
.form-sheet__title,
.detail-sheet__title {
    font-size: 34rpx;
    font-weight: 600;
    margin-bottom: 24rpx;
}
.form-sheet__row {
    display: flex;
    align-items: center;
    margin-bottom: 16rpx;
}
.form-sheet__label {
    width: 120rpx;
    font-size: 28rpx;
    color: #1A1A1A;
}
.form-sheet__fields {
    margin: 16rpx 0;
}
.form-field {
    margin-bottom: 20rpx;
}
.form-field__label {
    display: block;
    font-size: 26rpx;
    color: #6B7280;
    margin-bottom: 8rpx;
}
.form-sheet__actions {
    display: flex;
    gap: 20rpx;
    margin-top: 16rpx;
}
.detail-section {
    margin-top: 28rpx;
}
.detail-section__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 30rpx;
    font-weight: 600;
    margin-bottom: 16rpx;
}
.analysis__item {
    margin-bottom: 16rpx;
}
.analysis__label {
    font-size: 26rpx;
    font-weight: 600;
    color: #07C160;
    margin-bottom: 6rpx;
}
.analysis__value {
    font-size: 26rpx;
    color: #1A1A1A;
    line-height: 1.7;
    white-space: pre-wrap;
}
.detail-empty {
    font-size: 26rpx;
    color: #6B7280;
    text-align: center;
    padding: 24rpx 0;
}
.chat-wrap {
    height: 520rpx;
    border: 1rpx solid #EEF0F3;
    border-radius: 20rpx;
    overflow: hidden;
}
