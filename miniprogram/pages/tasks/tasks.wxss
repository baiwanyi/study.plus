.page {
    min-height: 100vh;
    background: #f7f8fa;
    padding-bottom: 40rpx;
}

.header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 28rpx 32rpx 16rpx;
}

.header-title {
    font-size: 40rpx;
    font-weight: 600;
    color: #1a1a1a;
}

.header-actions {
    display: flex;
    gap: 16rpx;
}

.center-wrap {
    display: flex;
    justify-content: center;
    padding: 120rpx 0;
}

.form {
    padding: 40rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
}

.form-title {
    font-size: 34rpx;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 24rpx;
}

.form-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24rpx 0;
}

.form-label {
    font-size: 28rpx;
    color: #1a1a1a;
}

.meta {
    font-size: 24rpx;
    color: #6b7280;
    margin-bottom: 24rpx;
}

.score-card {
    background: #f3fbf6;
    border-radius: 16rpx;
    padding: 24rpx;
    margin-bottom: 24rpx;
}

.score-comment {
    font-size: 26rpx;
    color: #1a1a1a;
    margin: 16rpx 0;
    line-height: 1.6;
}

.suggestions {
    margin-top: 8rpx;
}

.suggestion {
    font-size: 24rpx;
    color: #6b7280;
    line-height: 1.8;
}

.detail-actions {
    display: flex;
    gap: 16rpx;
    margin-top: 16rpx;
}
