<pc-layout
  isWide="{{isWide}}"
  user="{{user}}"
  children="{{children}}"
  currentChildId="{{currentChildId}}"
  currentPage="categories"
  bind:logout="onLogout"
>
<view class="page">
  <t-loading wx:if="{{loading}}" class="center" />
  <block wx:else>
    <view wx:if="{{list.length === 0}}" class="empty">暂无评语分类，点击下方新增</view>
    <t-cell-group theme="card" wx:else>
      <t-cell wx:for="{{list}}" wx:key="id" title="{{item.name}}" description="{{item.sample}}">
        <view slot="note">
          <t-button
            wx:if="{{isParent}}"
            size="extra-small"
            theme="light"
            variant="text"
            data-id="{{item.id}}"
            bind:tap="openEdit"
          >编辑</t-button>
          <t-button
            wx:if="{{isParent}}"
            size="extra-small"
            theme="danger"
            variant="text"
            data-id="{{item.id}}"
            bind:tap="onDelete"
          >删除</t-button>
        </view>
      </t-cell>
    </t-cell-group>
  </block>

  <view wx:if="{{isParent}}" class="footer">
    <t-button theme="primary" block bind:tap="openAdd">+ 新增分类</t-button>
  </view>

  <t-dialog
    visible="{{showForm}}"
    title="{{editingId ? '编辑分类' : '新增分类'}}"
    bind:confirm="onConfirm"
    bind:cancel="onCancel"
  >
    <view class="form">
      <t-input label="名称" value="{{form.name}}" placeholder="如：书写工整" bind:change="onNameChange" />
      <t-input label="图标" value="{{form.icon}}" placeholder="tdesign 图标名" bind:change="onIconChange" />
      <t-input label="示例评语" value="{{form.sample}}" placeholder="示例评语内容" bind:change="onSampleChange" />
    </view>
  </t-dialog>
</view>
</pc-layout>
