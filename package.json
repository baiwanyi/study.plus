{
    "name": "study-plus",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "tsc -b && vite build",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "tsx apps/db/migrate.ts",
        "db:push": "drizzle-kit push",
        "dev": "vite",
        "dev:all": "concurrently \"tsx watch apps/server.ts\" \"vite\"",
        "preview": "vite preview",
        "start": "tsx watch apps/server.ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:ui": "vitest --ui"
    },
    "dependencies": {
        "@libsql/client": "^0.14.0",
        "@uiw/react-md-editor": "^4.1.0",
        "dotenv": "^16.4.7",
        "drizzle-orm": "^0.38.3",
        "express": "^4.21.2",
        "lucide-react": "^1.8.0",
        "mermaid": "^11.0.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-player": "^3.4.0",
        "react-router-dom": "^7.1.0",
        "vite-tsconfig-paths": "^6.1.1"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/express": "^5.0.0",
        "@types/node": "^22.10.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@types/supertest": "^7.2.0",
        "@vitejs/plugin-react": "^4.3.4",
        "autoprefixer": "^10.4.20",
        "babel-plugin-react-compiler": "^1.0.0",
        "concurrently": "^9.2.1",
        "drizzle-kit": "^0.30.1",
        "jsdom": "^29.1.1",
        "postcss": "^8.4.49",
        "supertest": "^7.2.2",
        "tailwindcss": "^3.4.17",
        "tsx": "^4.19.2",
        "typescript": "^6.0.2",
        "vite": "^6.0.0",
        "vitest": "^3.1.2"
    }
}
