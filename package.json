{
    "name": "study-plus",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "concurrently \"pnpm --filter server dev\" \"pnpm --filter apps dev\"",
        "dev:server": "pnpm --filter server dev",
        "dev:apps": "pnpm --filter apps dev",
        "build": "pnpm --filter apps build",
        "db:migrate": "pnpm --filter server db:migrate",
        "start": "pnpm --filter server start",
        "test": "vitest run"
    },
    "devDependencies": {
        "concurrently": "^10.0.0",
        "vitest": "^4.1.6"
    }
}
