{
    "name": "study-plus",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "tsc -b && vite build",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "tsx apps/db/migrate.ts",
        "db:push": "drizzle-kit push",
        "dev": "vite",
        "dev:all": "concurrently \"tsx watch apps/server.ts\" \"vite\"",
        "preview": "vite preview",
        "start": "tsx watch apps/server.ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:ui": "vitest --ui"
    },
    "dependencies": {
        "@libsql/client": "^0.17.3",
        "@tailwindcss/postcss": "^4.3.0",
        "@uiw/react-md-editor": "^4.1.0",
        "dotenv": "^17.4.2",
        "drizzle-orm": "^0.45.2",
        "express": "^5.2.1",
        "html-to-image": "^1.11.13",
        "lucide-react": "^1.16.0",
        "mermaid": "^11.15.0",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "react-player": "^3.4.0",
        "react-router-dom": "^7.15.1",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@rolldown/plugin-babel": "^0.2.3",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/express": "^5.0.6",
        "@types/node": "^25.8.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/supertest": "^7.2.0",
        "@vitejs/plugin-react": "^6.0.2",
        "@vitest/ui": "4.1.7",
        "autoprefixer": "^10.5.0",
        "babel-plugin-react-compiler": "^1.0.0",
        "concurrently": "^10.0.0",
        "drizzle-kit": "^0.31.10",
        "jsdom": "^29.1.1",
        "postcss": "^8.5.14",
        "supertest": "^7.2.2",
        "tailwindcss": "^4.3.0",
        "tsx": "^4.22.1",
        "typescript": "^6.0.3",
        "vite": "^8.0.13",
        "vitest": "^4.1.6"
    }
}
